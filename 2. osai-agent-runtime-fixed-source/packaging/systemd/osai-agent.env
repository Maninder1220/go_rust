# =============================================================================
# File: packaging/systemd/osai-agent.env
# Purpose:
#   Example systemd environment file for the OSAI service.
#
# Where this fits in OSAI:
#   Loaded by osai-agent.service during Linux service startup.
#
# Topics to know before editing:
#   dotenv-style environment variables and service configuration.
#
# Important operational notes:
#   Do not store secrets here unless file permissions and host access are controlled.
# =============================================================================
OSAI_BIND=127.0.0.1:8000
OSAI_SCAN_INTERVAL_SECONDS=30
# Set this before binding to 0.0.0.0 or any non-loopback address.
# OSAI_AGENT_TOKEN=change-me-long-random-token

# =============================================================================
# File: .env.cognee.example
# Purpose:
#   Template environment file for Cognee REST/API behavior and local llama.cpp/Qwen inference settings.
#
# Where this fits in OSAI:
#   Copied to .env.cognee before running Docker Compose or Rust Ask OSAI flows that need memory and inference.
#
# Topics to know before editing:
#   dotenv-style environment variables and service configuration.
#
# Important operational notes:
#   Never commit real API keys here. Put secrets only in the local untracked .env.cognee file.
# =============================================================================
# Cognee Cloud / REST API configuration.
# Copy this file to .env.cognee and put real secrets only in .env.cognee.
# Cognee Cloud REST authentication uses the X-Api-Key header.
# Docs: https://docs.cognee.ai/cognee-cloud/ui/api-keys

# Paste your Cognee Cloud API Base URL here.
# Examples:
# COGNEE_API_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_URL=https://api.cognee.ai
COGNEE_API_URL=https://your-tenant.aws.cognee.ai

# Cognee Cloud docs usually use /api/v1.
# If your tenant returns 404 for /api/v1/recall but works with /api/recall, set this to /api.
COGNEE_API_PREFIX=/api/v1

# Paste your Cognee API key here. Never commit .env.cognee.
COGNEE_API_KEY=replace-me

# Paste these from Cognee Cloud for operator clarity and future audit tagging.
# The documented REST auth path only requires COGNEE_API_KEY.
COGNEE_TENANT_ID=replace-me
COGNEE_USER_ID=replace-me

# Keep false unless Cognee support tells you your tenant requires these headers.
OSAI_COGNEE_SEND_IDENTITY_HEADERS=false
OSAI_COGNEE_SEND_BEARER_AUTH=false

# Dataset used by Ask OSAI recall and memory ingestion.
COGNEE_DATASET=osai-agent-memory

# Production defaults for cloud memory.
OSAI_COGNEE_POLL_SECONDS=60
OSAI_COGNEE_HTTP_TIMEOUT_SECONDS=120
OSAI_COGNEE_RECALL_TIMEOUT_SECONDS=30
OSAI_COGNEE_RECALL_WITH_AI_OFF=true
OSAI_COGNEE_RUN_IN_BACKGROUND=true
OSAI_COGNEE_CHUNKS_PER_BATCH=4

# Keep Cognee memory useful. Raw scans are still stored every OSAI_POLL_SECONDS,
# but Cognee gets first scan, changed state, important state changes, and periodic summaries.
OSAI_COGNEE_MEMORY_MIN_INTERVAL_SECONDS=900
OSAI_COGNEE_MEMORY_ALWAYS_ON_FINDINGS=true

# Local Cognee docker switches. Not needed for Cognee Cloud, kept for local fallback.
REQUIRE_AUTHENTICATION=false
ENABLE_BACKEND_ACCESS_CONTROL=false

# Local-only Cognee relational database.
# Ignored when COGNEE_API_URL points to Cognee Cloud.
# In Docker Compose, Cognee reaches PostgreSQL by service name: postgres.
# Keep this DB separate from osai_agent because Cognee owns its own schema.
DB_PROVIDER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=cognee
DB_PASSWORD=cognee_password
DB_NAME=cognee_db

# Local-only absolute paths inside the Cognee container.
# Ignored when using Cognee Cloud.
# Cognee rejects relative paths for these settings.
SYSTEM_ROOT_DIRECTORY=/data/cognee_system
DATA_ROOT_DIRECTORY=/data/cognee_data

# Local-only Cognee memory stores.
# Ignored when using Cognee Cloud.
# pgvector lives inside PostgreSQL. Kuzu uses local files under Cognee data directories.
GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=pgvector

# Local-only Cognee LLM route.
# Ignored when using Cognee Cloud.
# docker-compose.storage.yml overrides this inside the Cognee container to:
# LLM_ENDPOINT=http://llama:8080/v1
# That routes Cognee to the dockerized llama.cpp/Qwen service.
LLM_PROVIDER=custom
LLM_MODEL=openai/osai-llm
LLM_ENDPOINT=http://llama:8080/v1
LLM_API_KEY=sk-no-key-required
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_INSTRUCTOR_MODE=json_mode
COGNEE_SKIP_CONNECTION_TEST=true

# Direct local inference route used by the Rust `osai-ask` binary on the host.
# Docker Compose publishes llama.cpp on localhost:8080 for host Rust binaries.
OSAI_LLM_ENDPOINT=http://127.0.0.1:8080/v1
OSAI_LLM_MODEL=osai-llm
OSAI_LLM_API_KEY=sk-no-key-required
OSAI_LLM_TIMEOUT_SECONDS=180
OSAI_LLM_MAX_TOKENS=420

# Local CPU embeddings for Cognee memory search.
# sentence-transformers/all-MiniLM-L6-v2 produces 384-dimensional embeddings.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

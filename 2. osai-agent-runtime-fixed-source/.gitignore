# =============================================================================
# File: .gitignore
# Purpose:
#   Prevents local state, secrets, build output, models, and runtime artifacts from entering Git.
#
# Where this fits in OSAI:
#   Keeps the repository source-focused while allowing large runtime artifacts to live locally.
#
# Topics to know before editing:
#   Docker/Git ignore patterns and build context hygiene.
#
# Important operational notes:
#   Do not remove model and .env ignores unless you intentionally want to publish sensitive or multi-GB files.
# =============================================================================
# Rust build output
/target/
debug/
release/
**/*.rs.bk

# Local env and secrets
.env
.env.*
!.env.example
!.env.*.example
.env.storage
.env.cognee
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/
secrets.*

# Runtime data generated by OSAI
data/*
!data/.gitkeep
*.jsonl
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm

# Local object-store / database dumps / backups
*.dump
*.sql.gz
*.backup
*.bak
*.tar
*.tar.gz
*.tgz

# Model weights and large AI artifacts
models/*
!models/.gitkeep
!models/README.md
*.gguf
*.safetensors
*.bin
*.onnx
*.pt
*.pth

# Python / Cognee local environments
.venv/
venv/
.venv-storage/
**/.venv-storage/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node/frontend local artifacts, if added later
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
dist/
build/

# Logs and temporary files
*.log
logs/
tmp/
temp/
.cache/
*.tmp

# Generated project packages
*.zip

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
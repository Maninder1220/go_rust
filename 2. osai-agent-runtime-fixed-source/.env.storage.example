# =============================================================================
# File: .env.storage.example
# Purpose:
#   Template environment file for the Rust storage worker, PostgreSQL, RustFS, and Cognee memory queue settings.
#
# Where this fits in OSAI:
#   Copied to .env.storage before running osai-storage-worker or related persistence workflows.
#
# Topics to know before editing:
#   dotenv-style environment variables and service configuration.
#
# Important operational notes:
#   Values must match Docker Compose ports, database users, object-store credentials, and bucket names.
# =============================================================================
# Rust agent API
OSAI_AGENT_URL=http://127.0.0.1:8000
OSAI_AGENT_TOKEN=
OSAI_POLL_SECONDS=30

# OSAI operational database. This DB stores scan summaries, findings, outbox state, and object-store pointers.
OSAI_POSTGRES_DSN=postgresql://osai:osai_password@127.0.0.1:5432/osai_agent

# RustFS/S3-compatible raw evidence store. This stores full snapshots and later command evidence/log bundles.
OBJECT_STORE_ENDPOINT=127.0.0.1:9000
OBJECT_STORE_ACCESS_KEY=rustfsadmin
OBJECT_STORE_SECRET_KEY=rustfsadmin
OBJECT_STORE_BUCKET=osai-agent
OBJECT_STORE_SECURE=false
OBJECT_STORE_REGION=us-east-1

# Cognee ingestion target
COGNEE_ENABLED=true
COGNEE_DATASET=osai-agent-memory
COGNEE_KNOWLEDGE_DATASET=osai-agent-knowledge

# Raw scan history is stored every OSAI_POLL_SECONDS.
# Cognee memory is throttled so repeated healthy scans do not flood long-term memory.
OSAI_COGNEE_MEMORY_MIN_INTERVAL_SECONDS=900
OSAI_COGNEE_MEMORY_ALWAYS_ON_FINDINGS=true
